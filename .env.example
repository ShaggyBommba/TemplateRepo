# Application settings
APP_ENV=development
APP_NAME=template
APP_VERSION=0.1.0
APP_DEBUG=false
APP_API_HOST=localhost
APP_API_PORT=8060
APP_HTMX_HOST=localhost
APP_HTMX_PORT=8061
APP_WORKER_POLL_INTERVAL=3
APP_WORKER_BATCH_LIMIT=100

# Logging settings
APP_LOGGING__LEVEL=INFO
APP_LOGGING__JSON_OUTPUT=false
APP_LOGGING__FILE_HANDLER_ENABLED=true
APP_LOGGING__FILE_PATH_PATTERN=.logs/{date}.log
APP_LOGGING__STREAM_HANDLER_ENABLED=true
APP_LOGGING__STREAM_FORMAT=[%(asctime)s] %(levelname)-8s [%(threadName)s] %(message)s
APP_LOGGING__STREAM_DATE_FORMAT=%H:%M:%S

# Database settings
APP_DATABASE__HOST=localhost
APP_DATABASE__PORT=5433
APP_DATABASE__HOST_PORT=5433
APP_DATABASE__USER=app
APP_DATABASE__PASSWORD=app
APP_DATABASE__DATABASE=app


# Outbox settings
APP_OUTBOX__DEFAULT_MAX_ATTEMPTS=3
APP_OUTBOX__CLAIM_TIMEOUT_SECONDS=300
APP_OUTBOX__OUTPUT_CHANNEL=default

# Keycloak settings
APP_KEYCLOAK__ADMIN_USER=admin
APP_KEYCLOAK__ADMIN_PASSWORD=admin
APP_KEYCLOAK__PORT=8080
APP_KEYCLOAK__BASE_URL=http://localhost:8080
APP_KEYCLOAK__REALM=template
APP_KEYCLOAK__CLIENT_ID=template
APP_KEYCLOAK__CLIENT_SECRET=template-secret
APP_KEYCLOAK__TIMEOUT_SECONDS=5.0

# Browser session settings
APP_SESSION__SECRET_KEY=development-session-secret
APP_SESSION__COOKIE_NAME=template_session
APP_SESSION__STATE_COOKIE_NAME=template_oauth_state
APP_SESSION__MAX_AGE_SECONDS=28800
APP_SESSION__SECURE=false
APP_SESSION__SAME_SITE=lax

# Heartbeat demo job settings
APP_HEARTBEAT__BEATS=3
APP_HEARTBEAT__INTERVAL=1.0
APP_HEARTBEAT__MAX_BEATS=60

# Monitoring settings
APP_DOZZLE__HOST_PORT=8888

# Reverse proxy (Traefik)
APP_TRAEFIK__HTTP_PORT=80
APP_TRAEFIK__HTTPS_PORT=443
APP_TRAEFIK__DASHBOARD_PORT=8089

# Reverse proxy hostnames
APP_KEYCLOAK__DOMAIN=keycloak.localhost
APP_DOZZLE__DOMAIN=dozzle.localhost
